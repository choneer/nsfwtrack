│       ├── items.html       # 条目列表
│       ├── detail.html      # 条目详情 + 标记
│       ├── tags.html        # 标签管理
│       ├── creators.html    # 创作者管理
│       ├── stats.html       # 统计
│       └── import.html      # 导入页面
├── tests/
├── data/                    # SQLite + 上传文件
├── docker-compose.yml
├── Dockerfile
└── requirements.txt
```

## 数据库模型（6 张表）

```sql
-- 条目表
CREATE TABLE items (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  title TEXT NOT NULL,
  -- 可选的来源信息（Phase 2 启用外部源时用）
  source TEXT,                  -- NULL/"veil"/"javdb"/"jmcomic"
  source_id TEXT,               -- 外部源 ID
  content_type TEXT DEFAULT 'other',
  cover_url TEXT,
  summary TEXT,
  release_date TEXT,
  extra TEXT,                   -- JSON，扩展用，Phase 2+ 再解析
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 创作者表（演员/作者/画师）
CREATE TABLE creators (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL UNIQUE,
  type TEXT DEFAULT 'other',     -- "actor"/"artist"/"author"/"other"
  avatar_url TEXT,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 标签表
CREATE TABLE tags (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL UNIQUE,
  category TEXT,                 -- 可选分类
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 条目-标签关联（多对多）
CREATE TABLE item_tags (
  item_id INTEGER REFERENCES items(id),
  tag_id INTEGER REFERENCES tags(id),
  PRIMARY KEY (item_id, tag_id)
);

-- 条目-创作者关联（多对多）
CREATE TABLE item_creators (
  item_id INTEGER REFERENCES items(id),
  creator_id INTEGER REFERENCES creators(id),
  PRIMARY KEY (item_id, creator_id)
);

-- 用户状态标记
CREATE TABLE user_item_states (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  item_id INTEGER NOT NULL REFERENCES items(id),
  status TEXT NOT NULL CHECK (status IN ('wish','watching','watched','like','dislike','ignore')),
  rating INTEGER CHECK (rating >= 1 AND rating <= 5),
  review TEXT,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  UNIQUE(item_id)
);
```

## API 路由

```
# 条目
GET    /api/items                    # 条目列表（分页）
POST   /api/items                    # 新增条目
GET    /api/items/{id}               # 条目详情
PUT    /api/items/{id}               # 编辑条目
DELETE /api/items/{id}               # 删除条目

# 状态标记
POST   /api/items/{id}/state         # 设置标记 {status, rating, review}
GET    /api/items/{id}/state         # 获取标记状态
DELETE /api/items/{id}/state         # 取消标记

# 标签
GET    /api/tags                     # 标签列表
POST   /api/tags                     # 创建标签
DELETE /api/tags/{id}                # 删除标签（关联也清）
PUT    /api/tags/{id}                # 编辑标签

# 创作者
GET    /api/creators                 # 创作者列表
POST   /api/creators                 # 创建创作者
GET    /api/creators/{id}            # 详情 + 作品列表
DELETE /api/creators/{id}

# 搜索
GET    /api/search?q=关键词&tag=xxx&status=watched&page=1

# 统计
GET    /api/stats/summary            # 总数/已看/喜欢/分类统计
GET    /api/stats/timeline           # 近期标记时间线

# 导入
POST   /api/import/csv               # CSV 导入
POST   /api/import/json              # JSON 导入
```

## 可选功能：NSFW 图片源（Boudoir / Veil）

如果 Phase 1 想做点有趣的东西，加一个「随机探索」功能：

```
GET /api/explore/random
  → 调 veil.ortlinde.com/v1/gallery/random
  → 拿到图集标题、第一张图的 ID、标签、分类
  → 存入 items 表（如有重复跳）
  → 返回条目详情 → 用户可标记
```

复杂度极低（一个 HTTP 请求），为 Phase 2 的外部源 adapter 打基础。

## Phase 1 执行顺序

```
Day 1: 项目骨架 + 数据库模型 + items CRUD API
Day 2: 标签 + 创作者管理 + 关联
Day 3: 状态标记 + 搜索 + 统计
Day 4: 前端页面（列表 + 详情 + 标签 + 统计 + 导入）
Day 5: CSV/JSON 导入 + Docker 部署 + 测试
```

## 安全边界

- 默认局域网部署
- 日志脱敏（不输出 `extra`、`summary` 等字段原始值）
- `data/` 目录 Docker 卷持久化
- 不保存外部 token/cookie

## 数据来源

Phase 1 数据通过以下方式进入系统：

1. **手动录入**：Web UI 表单新增条目
2. **CSV 导入**：上传 CSV，支持 `title,tags,creators,status,rating,review` 列
3. **JSON 导入**：同上的 JSON 格式
4. **NSFW 图片 API（可选）**：`/api/explore/random` 拉一张随机图入库
